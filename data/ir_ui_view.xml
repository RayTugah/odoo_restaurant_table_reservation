                    margin: 0 !important;
                    padding: 0 !important;
                    border: 0 !important;
                    outline: 0 !important;
                    box-shadow: none !important;
                    background: #fff !important;
                }

                * {
                    box-sizing: border-box;
                    border: 0 !important;
                    outline: 0 !important;
                    box-shadow: none !important;
                }

                .page,
                .article,
                .o_report_layout,
                .o_report_layout_standard,
                .o_company_1_layout,
                .header,
                .footer,
                .oe_structure {
                    margin: 0 !important;
                    padding: 0 !important;
                    border: 0 !important;
                    outline: 0 !important;
                    box-shadow: none !important;
                    background: transparent !important;
                }

                .ticket-page {
                    width: 90mm;
                    margin: 0 !important;
                    padding: 1mm !important;
                    border: none !important;
                    outline: none !important;
                    box-shadow: none !important;
                    font-family: "Courier New", monospace;
                    font-size: 11px;
                    color: #000;
                    background: #fff;
                }

                .ticket-center {
                    text-align: center;
                }

                .ticket-title {
                    font-size: 18px;
                    font-weight: bold;
                    margin: 0 0 4px 0;
                }

                .ticket-sep {
                    border-top: 1px dashed #000 !important;
                    margin: 6px 0;
                }

                .ticket-head {
                    font-size: 12px;
                    font-weight: bold;
                    text-align: center;
                    margin: 0;
                    padding: 0;
                }

                .ticket-line {
                    margin: 0 0 4px 0;
                    padding: 0;
                }

                .ticket-line-table {
                    width: 100%;
                    border-collapse: collapse;
                    table-layout: fixed;
                    border: none !important;
                    margin: 0;
                    padding: 0;
                }

                .ticket-line-table tr,
                .ticket-line-table td,
                .ticket-line-table tbody {
                    border: none !important;
                    margin: 0;
                    padding: 0;
                }

                .ticket-line-left {
                    width: 70%;
                    vertical-align: top;
                    text-align: left;
                    word-break: break-word;
                    padding: 0;
                }

                .ticket-line-right {
                    width: 30%;
                    vertical-align: top;
                    text-align: right;
                    white-space: nowrap;
                    padding: 0;
                }

                .ticket-line-name {
                    line-height: 1.15;
                    margin: 0;
                    padding: 0;
                }

                .ticket-sub {
                    margin: 0;
                    padding: 0;
                    font-size: 10px;
                    line-height: 1.1;
                }

                .ticket-totals {
                    margin-top: 10px;
                    width: 100%;
                    padding: 0;
                }

                .ticket-total-row {
                    display: flex;
                    justify-content: space-between;
                    width: 100%;
                    margin: 0;
                    padding: 0;
                }

                .ticket-grand-total {
                    font-size: 16px;
                    font-weight: bold;
                    border-top: 1px solid #000 !important;
                    margin-top: 4px;
                    padding-top: 4px;
                }

                .ticket-footer {
                    margin-top: 12px;
                    text-align: center;
                    font-size: 11px;
                    padding: 0;
                }
            </style>
            <div class="ticket-center">
              <div class="ticket-title">CAMPING LA FUENTE</div>
                Camino Bocamina, 30626<br />
                        Los Baños de Fortuna, Murcia.<br />
                        968 68 62 43<br />
                        Hotel Fuente de los Baños Fortuna S.A.<br />
                        A-30075063
            </div>
            <div class="ticket-sep" />
            <div class="ticket-head">
                Ticket: <span t-esc="o.display_name or o.id" />
              <br />
                        Fecha:
                <t t-if="o.x_studio_fecha_grupo">
                <span t-esc="o.x_studio_fecha_grupo.strftime('%d/%m/%Y')" />
              </t>
              <t t-else="">
                <span t-esc="o.x_studio_fecha_y_hora and o.x_studio_fecha_y_hora.strftime('%d/%m/%Y')" />
                <br />
                <span t-esc="o.x_studio_fecha_y_hora and o.x_studio_fecha_y_hora.strftime('%H:%M')" />
              </t>
            </div>
            <div class="ticket-sep" />
            <t t-foreach="o.x_studio_productos" t-as="linea">
              <t t-if="(linea.x_studio_cantidad_1 or 0) != 0">
                <div class="ticket-line">
                  <table class="ticket-line-table">
                    <tr>
                      <td class="ticket-line-left">
                        <div class="ticket-line-name">
                          <span t-esc="linea.x_studio_cantidad_1" />
                          <span> </span>
                          <span t-esc="linea.x_studio_nombre_producto and linea.x_studio_nombre_producto.display_name or ''" />
                        </div>
                        <div class="ticket-sub">
                                        (<span t-esc="linea.x_studio_related_field_u3_1jk667e5u" />% IVA incl.)
                                    </div>
                      </td>
                      <td class="ticket-line-right">
                        <span t-esc="'%.2f €' % (linea.x_studio_subtotal or 0.0)" />
                      </td>
                    </tr>
                  </table>
                </div>
              </t>
            </t>
            <div class="ticket-totals">
              <div class="ticket-total-row">
                    Subtotal:
                    <span t-esc="'%.2f €' % (o.x_studio_neto or 0.0)" />
              </div>
              <div class="ticket-total-row">
                    IVA:
                    <span t-esc="'%.2f €' % (o.x_studio_iva or 0.0)" />
              </div>
              <div class="ticket-total-row ticket-grand-total">
                    Total:
                    <span t-esc="'%.2f €' % (o.x_studio_total or 0.0)" />
              </div>
              <div class="ticket-sep" />
              <t t-if="o.x_studio_numero_personas">
                <div class="ticket-total-row ticket-grand-total" style="border-top: none !important; margin-top: 0; padding-top: 0;">
                        Personas:
                        <span t-esc="o.x_studio_numero_personas" />
                </div>
              </t>
              <t t-if="o.x_studio_total_grupo">
                <div class="ticket-total-row ticket-grand-total" style="border-top: none !important; margin-top: 0; padding-top: 0;">
                        Total grupo:
                        <span t-esc="'%.2f €' % (o.x_studio_total_grupo or 0.0)" />
                </div>
              </t>
            </div>
            <t t-if="o.x_studio_observaciones_externas">
              <div class="ticket-sep" />
              <div class="ticket-center" style="font-size: 11px;">
                <strong>Observaciones:</strong>
                <br />
                <span t-esc="o.x_studio_observaciones_externas" />
              </div>
            </t>
            <div class="ticket-footer">
                Complejo Hostelero La Fuente<br />
                        Los Baños de Fortuna (Murcia)<br />
                        Gracias por su visita
            </div>
          </div>
        </t>
      </t>
    </field>
