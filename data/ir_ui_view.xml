                  <div style="font-size:20px; font-weight:600;" name="studio_div_a5c946">
                    <field name="x_name" />
                  </div>
                  <div class="text-muted mt-1" style="font-size:13px;" name="studio_div_6b6b9f">
                    <field name="x_studio_notes" />
                  </div>
                  <div class="mt-1" style="font-size:12px; font-weight:600; display:flex; gap:6px; flex-wrap:wrap;" name="studio_div_66d40b">
