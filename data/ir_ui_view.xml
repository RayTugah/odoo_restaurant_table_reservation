  <record id="odoo_studio_default__8727f8cf-bb94-4304-8c00-7710f2faad40" model="ir.ui.view" context="{'studio': True}">
    <field name="arch" type="xml">
      <data>
        <xpath expr="/form//field[@name='x_studio_date_start']" position="replace">
          <field name="x_studio_fecha_1" required="True" />
          <field name="x_studio_hora_1" required="True" />
          <field name="x_studio_numero_adultos_1" required="True" />
          <field name="x_studio_numero_ninos" />
          <field name="x_studio_numero_personas" />
          <field name="x_studio_fecha_formateada" invisible="True" />
        </xpath>
        <xpath expr="/form//field[@name='x_studio_tag_ids']" position="after">
          <field name="x_studio_pedido_de_venta_vinculado" />
          <field name="x_studio_ticket_tpv_vinculado" options="{'create_name_field': 'x_name'}" />
          <field name="x_studio_reserva_piscina_vinculada" options="{'create_name_field': 'code'}" force_save="1" readonly="True" />
          <field name="x_studio_estado" widget="radio" invisible="True" />
        </xpath>
        <xpath expr="/form//field[@name='x_studio_tag_ids']" position="attributes">
          <attribute name="string">Etiquetas</attribute>
        </xpath>
        <xpath expr="/form//field[@name='x_studio_notes']" position="after">
          <field name="x_studio_observaciones_externas_1" placeholder="Poner todo el texto seguido sin hacer saltos de linea" />
        </xpath>
        <xpath expr="/form/sheet/group[2]" position="attributes">
          <attribute name="string">OBSERVACIONES INTERNAS</attribute>
        </xpath>
        <xpath expr="/form//field[@name='x_studio_notes']" position="attributes">
          <attribute name="placeholder">Escribe tus observaciones internas aquí...</attribute>
        </xpath>
      </data>
    </field>
    <field name="inherit_id" ref="default_form_view_fo_22ac9ae5-e7ba-4cef-ae19-15820366087e" />
    <field name="mode">extension</field>
    <field name="model">x_camping_reservamesas</field>
    <field name="name">Odoo Studio: Default form view for x_camping_reservamesas customization</field>
    <field name="priority">99</field>
    <field name="type">form</field>
  </record>
