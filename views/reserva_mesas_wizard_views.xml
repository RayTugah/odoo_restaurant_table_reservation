<odoo>
    <record id="view_reserva_mesas_wizard_form" model="ir.ui.view">
        <field name="name">reserva.mesas.wizard.form</field>
        <field name="model">reserva.mesas.wizard</field>
        <field name="arch" type="xml">
            <form string="Nueva reserva">
                <sheet>
                    <group>
                        <field name="x_name"/>
                        <field name="x_studio_partner_id"/>
                        <field name="x_studio_partner_phone"/>
                        <field name="x_studio_partner_email"/>
                        <field name="x_studio_fecha_1" required="1"/>
                        <field name="x_studio_hora_1" required="1"/>
                        <field name="x_studio_numero_adultos_1" required="1"/>
                        <field name="x_studio_numero_ninos"/>
                        <field name="x_studio_numero_personas" readonly="1"/>
                        <field name="x_studio_idreservapiscina_1" invisible="1"/>
                        <field name="x_studio_tag_ids" widget="many2many_tags" string="Etiquetas"/>
                        <field name="x_studio_notes"/>
                        <field name="x_studio_observaciones_externas_1"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_guardar" type="object" string="Guardar" class="btn btn-primary"/>
                    <button string="Cancelar" special="cancel" class="btn btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_reserva_mesas_wizard" model="ir.actions.act_window">
        <field name="name">Nueva reserva</field>
        <field name="res_model">reserva.mesas.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_reserva_mesas_wizard_form"/>
        <field name="target">new</field>
    </record>
</odoo>